-- Sistema de notificações
local notificationSystem = {}
notificationSystem.__index = notificationSystem

function notificationSystem.new()
    local self = setmetatable({}, notificationSystem)
    self.container = Instance.new("ScreenGui")
    self.container.Name = "NotificationContainer"
    self.container.Parent = player.PlayerGui
    self.container.IgnoreGuiInset = true
    self.container.DisplayOrder = 999
    
    self.frame = Instance.new("Frame")
    self.frame.Size = UDim2.new(0, 320, 0, 0)
    self.frame.Position = UDim2.new(1, -340, 0, 20)
    self.frame.BackgroundTransparency = 1
    self.frame.Parent = self.container
    
    self.listLayout = Instance.new("UIListLayout")
    self.listLayout.Padding = UDim.new(0, 8)
    self.listLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    self.listLayout.Parent = self.frame
    
    return self
end

function notificationSystem:show(message, type)
    type = type or "info"
    
    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(1, 0, 0, 0)
    notifFrame.BackgroundColor3 = COLORS.Surface
    notifFrame.BorderSize = 0
    notifFrame.ClipsDescendants = true
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = notifFrame
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = type == "success" and COLORS.Success or type == "warning" and COLORS.Warning or COLORS.NeonBlue
    stroke.Thickness = 1.5
    stroke.Transparency = 0.5
    stroke.Parent = notifFrame
    
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 30, 1, 0)
    iconLabel.Position = UDim2.new(0, 8, 0, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = type == "success" and "✓" or type == "warning" and "!" or "i"
    iconLabel.TextColor3 = type == "success" and COLORS.Success or type == "warning" and COLORS.Warning or COLORS.NeonBlue
    iconLabel.TextSize = 18
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.Parent = notifFrame
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -50, 1, 0)
    textLabel.Position = UDim2.new(0, 40, 0, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = message
    textLabel.TextColor3 = COLORS.Text
    textLabel.TextSize = 13
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.Font = Enum.Font.Gotham
    textLabel.Parent = notifFrame
    
    notifFrame.Parent = self.frame
    
    -- Animação de entrada
    local targetHeight = 45
    notifFrame.Size = UDim2.new(1, 0, 0, 0)
    
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local sizeTween = TweenService:Create(notifFrame, tweenInfo, {Size = UDim2.new(1, 0, 0, targetHeight)})
    sizeTween:Play()
    
    -- Animação de saída após 3 segundos
    task.delay(3, function()
        local fadeOut = TweenService:Create(notifFrame, TweenInfo.new(0.3), {BackgroundTransparency = 1, TextTransparency = 1})
        fadeOut:Play()
        fadeOut.Completed:Connect(function()
            notifFrame:Destroy()
        end)
    end)
end

-- Criação do círculo de FOV
function createFOVCircle()
    if fovCircle then
        fovCircle:Destroy()
    end
    
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "FOVCircle"
    screenGui.Parent = player.PlayerGui
    screenGui.IgnoreGuiInset = true
    screenGui.DisplayOrder = 998
    
    local circleFrame = Instance.new("Frame")
    circleFrame.Size = UDim2.new(0, fovRadius * 2, 0, fovRadius * 2)
    circleFrame.Position = UDim2.new(0.5, -fovRadius, 0.5, -fovRadius)
    circleFrame.BackgroundTransparency = 1
    circleFrame.Parent = screenGui
    
    local circle = Instance.new("ImageLabel")
    circle.Size = UDim2.new(1, 0, 1, 0)
    circle.BackgroundTransparency = 1
    circle.Image = "rbxassetid://2665431318" -- Círculo branco
    circle.ImageColor3 = COLORS.NeonBlue
    circle.ImageTransparency = 0.7
    circle.ScaleType = Enum.ScaleType.Fit
    circle.Parent = circleFrame
    
    local innerGlow = Instance.new("ImageLabel")
    innerGlow.Size = UDim2.new(1, 0, 1, 0)
    innerGlow.BackgroundTransparency = 1
    innerGlow.Image = "rbxassetid://2665431318"
    innerGlow.ImageColor3 = COLORS.NeonBlue
    innerGlow.ImageTransparency = 0.85
    innerGlow.ScaleType = Enum.ScaleType.Fit
    innerGlow.Parent = circleFrame
    
    -- Efeito de brilho pulsante
    spawn(function()
        while circleFrame and circleFrame.Parent do
            for i = 0.7, 0.5, -0.01 do
                if not circleFrame or not circleFrame.Parent then break end
                circle.ImageTransparency = i
                innerGlow.ImageTransparency = i + 0.15
                task.wait(0.03)
            end
            for i = 0.5, 0.7, 0.01 do
                if not circleFrame or not circleFrame.Parent then break end
                circle.ImageTransparency = i
                innerGlow.ImageTransparency = i + 0.15
                task.wait(0.03)
            end
        end
    end)
    
    fovCircle = screenGui
    return screenGui
end

-- Toggle do círculo
function toggleFOV()
    fovVisible = not fovVisible
    
    if fovVisible then
        if not fovCircle then
            createFOVCircle()
        end
        fovCircle.Enabled = true
        notificationSystem:show("FOV Circle ativado (Raio: " .. fovRadius .. ")", "success")
    else
        if fovCircle then
            fovCircle.Enabled = false
        end
        notificationSystem:show("FOV Circle desativado", "warning")
    end
end

-- Atualizar tamanho do círculo
function updateFOVSize(newRadius)
    fovRadius = newRadius
    
    if fovCircle then
        fovCircle:Destroy()
        fovCircle = nil
    end
    
    if fovVisible then
        createFOVCircle()
        notificationSystem:show("Raio do FOV alterado para " .. newRadius, "success")
    end
end

